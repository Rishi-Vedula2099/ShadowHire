# ShadowHire Backend Environment
# Copy to .env and fill in values

# App
APP_NAME=ShadowHire
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./shadowhire.db

# JWT Auth
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI / LLM (for future integration)
OPENAI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
